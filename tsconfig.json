{
  "compilerOptions": {
    "target": "ES2020",                  // какой JS генерировать
    "module": "CommonJS",                // для Node.js
    "outDir": "dist",                     // куда складывать JS
    "rootDir": "src",                     // корень TS файлов
    "emitDeclarationOnly": false,
    "declaration": true,                  // генерировать .d.ts
    "declarationDir": "dist/types",       // куда складывать типы
    "strict": true,                        // строгая проверка TS
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}